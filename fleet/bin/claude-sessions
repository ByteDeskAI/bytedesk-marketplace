#!/usr/bin/env bash
# claude-sessions — dashboard + control plane for spawn-claude-feature sessions.
#
# Usage:
#   claude-sessions                       # list all sessions (status table)
#   claude-sessions watch                 # live-update the table every 2s
#   claude-sessions attach <ticket>       # tmux attach -d -t
#   claude-sessions tail   <ticket>       # tail -f the log
#   claude-sessions log    <ticket>       # less the log
#   claude-sessions peek   <ticket> [N]   # last N pane lines (default 30)
#   claude-sessions send   <ticket> <msg> # paste a message into the session
#   claude-sessions kill   <ticket> [--children|--tree]  # stop session + cleanup
#   claude-sessions tree   [<ticket>]     # show parent → child hierarchy
#   claude-sessions cost   [<ticket>]     # token usage and rough cost per session
#   claude-sessions tui                   # interactive menu (no fzf needed)
#   claude-sessions clean [-q|--quiet]    # prune meta files for dead sessions
#                                         # (alias: cleanup; --quiet silences stdout)
#   claude-sessions notify [--interval N] [--once]   # desktop alerts + rules engine
#   claude-sessions events <ticket> [--since=TS] [--kinds=K,..] [--json|--plain] [--follow]
#                                         # tool-level events for a session (BDP-372)
#   claude-sessions web                  # print dashboard URL (server is a monitor)
#
# Rules engine (chain orchestration that survives chat session ends):
#   claude-sessions rules                           # list pending rules
#   claude-sessions rules cancel <id>               # remove a pending rule
#   claude-sessions rules clear                     # remove all rules
#
# All session state lives under ${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/fleet}/
# projects/<PROJECT_KEY>/, where PROJECT_KEY is a 12-char sha256 of the canonical
# repo working-tree path. Layout per project:
#   sessions/<TICKET>/{meta,log,events,events.offset,events.err,results/}
#   notify/{config.toml,log,fifo,pid}
#   rules/<id>.json   rules/log/<id>.{fired,cancelled,timed-out}.json

set -euo pipefail

# ─── Per-project data layout (BDM-3) ──────────────────────────────────────────
# Resolves the canonical working-tree dir for the current invocation. For
# secondary git worktrees (e.g. a fleet child running in
# <repo>/.claude/worktrees/<TICKET>-<slug>) `git rev-parse --git-common-dir`
# returns the main repo's `.git` dir, so realpath+dirname yields the SAME
# canonical path the main checkout sees. Outside any git tree, falls back to
# CLAUDE_PROJECT_DIR (set by Claude Code) or PWD.
_canonical_dir() {
  local gcd
  if gcd="$(git rev-parse --git-common-dir 2>/dev/null)" && [[ -n "$gcd" ]]; then
    dirname "$(realpath "$gcd")"
  else
    realpath "${CLAUDE_PROJECT_DIR:-$PWD}"
  fi
}

_project_key() { _canonical_dir | sha256sum | cut -d' ' -f1 | head -c 12; }

# Base data dir. Falls back to $HOME/.claude/plugins/data/fleet for invocations
# outside a Claude Code session (so ad-hoc CLI use still works).
_data_root()    { echo "${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/fleet}"; }
_project_dir()  { echo "$(_data_root)/projects/$(_project_key)"; }
_sessions_root(){ echo "$(_project_dir)/sessions"; }
_session_dir()  { echo "$(_sessions_root)/$1"; }   # arg: TICKET
_notify_dir()   { echo "$(_project_dir)/notify"; }
_rules_dir()    { echo "$(_project_dir)/rules"; }
_web_dir()      { echo "$(_project_dir)/web"; }

# Resolve once at load time so dependent vars (RULES_DIR, NOTIFY_CONFIG, etc.)
# observe the same project even if cwd changes mid-run.
SESSIONS_DIR="$(_sessions_root)"
RULES_DIR="$(_rules_dir)"
RULES_LOG_DIR="$(_rules_dir)/log"
mkdir -p "$SESSIONS_DIR" "$RULES_LOG_DIR"

# Color codes (auto-disabled if not a tty)
if [[ -t 1 ]]; then
  C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'
  C_CYAN=$'\033[36m'; C_RESET=$'\033[0m'
else
  C_DIM=""; C_BOLD=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_CYAN=""; C_RESET=""
fi

# Read a key from a meta file. Usage: meta_get <file> <key>
meta_get() {
  awk -F= -v k="$2" '$1==k {sub(/^[^=]+=/, ""); print; exit}' "$1"
}

# All known sessions (from per-session meta files). Echoes ticket names,
# one per line. Layout: $SESSIONS_DIR/<TICKET>/meta.
list_known_sessions() {
  shopt -s nullglob
  local f
  for f in "$SESSIONS_DIR"/*/meta; do
    basename "$(dirname "$f")"
  done
}

# Resolve a meta file by ticket. Errors if missing.
meta_for() {
  local ticket="$1"
  local f="$SESSIONS_DIR/${ticket}/meta"
  [[ -f "$f" ]] || { echo "no meta for ticket: $ticket" >&2; return 65; }
  echo "$f"
}

# Determine session state by inspecting the last few lines of the log.
session_state() {
  local log="$1"
  if [[ ! -s "$log" ]]; then echo "starting"; return; fi
  local tail
  tail=$(tail -n 20 "$log" 2>/dev/null || true)
  # Heuristics — order matters; first match wins.
  if grep -qiE '(error|failed|cannot|denied)' <<<"$tail"; then echo "error"
  elif grep -qiE '(waiting|running|swirling|thinking|↓ [0-9]+ tokens)' <<<"$tail"; then echo "working"
  elif grep -qiE '(approve|allow this|permission|y/n)' <<<"$tail"; then echo "needs-input"
  elif grep -qiE '(✓|✅|complete|done|merged)' <<<"$tail"; then echo "done"
  else echo "idle"
  fi
}

# Color a state string.
color_state() {
  case "$1" in
    working)     echo "${C_CYAN}${1}${C_RESET}" ;;
    needs-input) echo "${C_YELLOW}${1}${C_RESET}" ;;
    error)       echo "${C_RED}${1}${C_RESET}" ;;
    done)        echo "${C_GREEN}${1}${C_RESET}" ;;
    starting)    echo "${C_DIM}${1}${C_RESET}" ;;
    *)           echo "${1}" ;;
  esac
}

# Last activity = mtime of log file as relative time.
ago() {
  local f="$1"
  [[ -f "$f" ]] || { echo "?"; return; }
  local now mt
  now=$(date +%s)
  mt=$(stat -c %Y "$f")
  local d=$((now - mt))
  if   (( d < 60 ));    then echo "${d}s ago"
  elif (( d < 3600 ));  then echo "$((d/60))m ago"
  elif (( d < 86400 )); then echo "$((d/3600))h ago"
  else                       echo "$((d/86400))d ago"
  fi
}

# ─── Lineage helpers (parent / children / depth) ─────────────────────────────

# Tickets whose meta declares parent=<ticket>.
children_of() {
  local parent="$1"
  shopt -s nullglob
  local f t p
  for f in "$SESSIONS_DIR"/*/meta; do
    p=$(meta_get "$f" parent)
    if [[ "$p" == "$parent" ]]; then
      basename "$(dirname "$f")"
    fi
  done
}

# All descendants of a ticket (BFS).
descendants_of() {
  local root="$1"
  local -a queue=( "$root" )
  while [[ ${#queue[@]} -gt 0 ]]; do
    local cur="${queue[0]}"
    queue=( "${queue[@]:1}" )
    local child
    while IFS= read -r child; do
      [[ -n "$child" ]] || continue
      echo "$child"
      queue+=( "$child" )
    done < <(children_of "$cur")
  done
}

# Sessions with no parent (the roots).
roots() {
  shopt -s nullglob
  local f p
  for f in "$SESSIONS_DIR"/*/meta; do
    p=$(meta_get "$f" parent)
    [[ -z "$p" ]] && basename "$(dirname "$f")"
  done
}

# ─── Cost / tokens / runtime ──────────────────────────────────────────────────

# Approx blended price per million tokens (Opus 4.7 ~ $30/M assuming 90/10 split).
# Override with CLAUDE_SESSIONS_USD_PER_M_TOKENS env var.
USD_PER_M_TOKENS="${CLAUDE_SESSIONS_USD_PER_M_TOKENS:-30}"

# Latest token count from a session log. The Claude REPL emits "<N> tokens"
# (sometimes "<N>k tokens", sometimes the status bar collapses whitespace
# producing "107772tokens"); we grab the largest integer match in the last
# 200 lines. Always exits 0 so the caller's set -e doesn't trip on no-match.
latest_tokens() {
  local log="$1"
  [[ -s "$log" ]] || { echo 0; return 0; }
  local result
  result=$(tail -n 200 "$log" 2>/dev/null \
    | grep -oE '[0-9]+(\.[0-9]+)?k?[[:space:]]*tokens' 2>/dev/null \
    | awk '{
        s = $1; n = s; sub(/k$/, "", s);
        v = s + 0;
        if (n ~ /k$/) v *= 1000;
        if (v > max) max = v;
      } END { printf "%d\n", max+0 }' 2>/dev/null) || result=0
  echo "${result:-0}"
}

# Rough USD estimate for a token count.
est_cost_usd() {
  local tokens="$1"
  awk -v t="$tokens" -v r="$USD_PER_M_TOKENS" 'BEGIN { printf "%.2f", t / 1000000 * r }'
}

# Format token count compactly (1234 -> "1.2k", 87000 -> "87.0k").
fmt_tokens() {
  awk -v t="$1" 'BEGIN {
    if (t >= 1000000) printf "%.2fM", t/1000000;
    else if (t >= 1000) printf "%.1fk", t/1000;
    else printf "%d", t;
  }'
}

# Minutes since session started (from meta `started=` field).
runtime_min() {
  local meta="$1"
  local s
  s=$(meta_get "$meta" started)
  [[ -n "$s" ]] || { echo 0; return; }
  local started_epoch now
  started_epoch=$(date -d "$s" +%s 2>/dev/null || echo 0)
  now=$(date +%s)
  echo $(( (now - started_epoch) / 60 ))
}

# ─── Tree view ────────────────────────────────────────────────────────────────

# Recursively print a single subtree with depth-prefixed lines.
_print_subtree() {
  local ticket="$1" prefix="$2" is_last="$3"
  local meta="$SESSIONS_DIR/${ticket}/meta"
  [[ -f "$meta" ]] || return
  local log session state branch tokens cost
  log=$(meta_get "$meta" log)
  session=$(meta_get "$meta" session)
  branch=$(meta_get "$meta" branch)
  state=$(session_state "$log")
  tokens=$(latest_tokens "$log")
  cost=$(est_cost_usd "$tokens")
  local alive
  if tmux has-session -t "$session" 2>/dev/null; then alive="${C_GREEN}●${C_RESET}"
  else alive="${C_DIM}○${C_RESET}"; state="${C_DIM}gone${C_RESET}"; fi

  local connector="├─"
  [[ "$is_last" == "1" ]] && connector="└─"
  if [[ -z "$prefix" ]]; then connector=""; fi

  printf "%s%s %b %-12s %-21s %-8s %s\n" \
    "$prefix" "$connector" "$alive" "$ticket" \
    "$(color_state "$state")" \
    "$(fmt_tokens "$tokens")/\$$cost" \
    "${branch:0:50}"

  local kids
  mapfile -t kids < <(children_of "$ticket")
  local n=${#kids[@]} i=0
  for k in "${kids[@]}"; do
    i=$((i+1))
    local child_prefix="$prefix"
    if [[ -n "$prefix" ]]; then
      [[ "$is_last" == "1" ]] && child_prefix="${prefix}   " || child_prefix="${prefix}│  "
    else
      child_prefix="   "
    fi
    [[ $i -eq $n ]] && _print_subtree "$k" "$child_prefix" 1 || _print_subtree "$k" "$child_prefix" 0
  done
}

cmd_tree() {
  local root="${1:-}"
  printf "${C_BOLD}%-2s   %-12s %-12s %-19s %s${C_RESET}\n" \
    "" "TICKET" "STATE" "TOK / EST" "BRANCH"
  if [[ -n "$root" ]]; then
    _print_subtree "$root" "" 1
  else
    local r
    mapfile -t r < <(roots)
    if [[ ${#r[@]} -eq 0 ]]; then
      echo "${C_DIM}No sessions.${C_RESET}"
      return
    fi
    for t in "${r[@]}"; do
      _print_subtree "$t" "" 1
    done
  fi
}

# ─── Cost view ────────────────────────────────────────────────────────────────

cmd_cost() {
  local target="${1:-}"
  local total=0
  printf "${C_BOLD}%-14s %-10s %-10s %-12s %s${C_RESET}\n" \
    "TICKET" "TOKENS" "EST USD" "RUNTIME" "STATE"
  local sessions
  if [[ -n "$target" ]]; then
    mapfile -t sessions < <(echo "$target"; descendants_of "$target")
  else
    mapfile -t sessions < <(list_known_sessions)
  fi
  for t in "${sessions[@]}"; do
    [[ -n "$t" ]] || continue
    local meta="$SESSIONS_DIR/${t}/meta"
    [[ -f "$meta" ]] || continue
    local log state tokens cost rt
    log=$(meta_get "$meta" log)
    state=$(session_state "$log")
    tokens=$(latest_tokens "$log")
    cost=$(est_cost_usd "$tokens")
    rt=$(runtime_min "$meta")
    total=$(awk -v a="$total" -v b="$cost" 'BEGIN { printf "%.2f", a+b }')
    printf "%-14s %-10s \$%-9s %-12s %s\n" \
      "$t" "$(fmt_tokens "$tokens")" "$cost" "${rt}m" "$(color_state "$state")"
  done
  echo
  echo "${C_BOLD}Total estimated:${C_RESET} \$$total  (rate: \$${USD_PER_M_TOKENS}/M tokens; override CLAUDE_SESSIONS_USD_PER_M_TOKENS)"
}

# Print the dashboard table.
cmd_list() {
  local sessions
  mapfile -t sessions < <(list_known_sessions)
  if [[ ${#sessions[@]} -eq 0 ]]; then
    echo "${C_DIM}No claude sessions. Spawn one: spawn-claude-feature BDP-N slug \"prompt\"${C_RESET}"
    return
  fi
  printf "${C_BOLD}%-14s %-12s %-12s %-12s %-40s %s${C_RESET}\n" \
    "TICKET" "STATE" "ACTIVITY" "PARENT" "BRANCH" "●"
  for t in "${sessions[@]}"; do
    local meta="$SESSIONS_DIR/${t}/meta"
    local log session branch state alive parent
    log=$(meta_get "$meta" log)
    session=$(meta_get "$meta" session)
    branch=$(meta_get "$meta" branch)
    parent=$(meta_get "$meta" parent)
    state=$(session_state "$log")
    if tmux has-session -t "$session" 2>/dev/null; then alive="${C_GREEN}●${C_RESET}"
    else alive="${C_DIM}○ dead${C_RESET}"; state="${C_DIM}gone${C_RESET}"; fi
    printf "%-14s %-21s %-12s %-12s %-40s %b\n" \
      "$t" "$(color_state "$state")" "$(ago "$log")" "${parent:--}" "${branch:0:40}" "$alive"
  done
  echo
  echo "${C_DIM}For hierarchy view: claude-sessions tree   |   For cost: claude-sessions cost${C_RESET}"
}

cmd_watch() { exec watch -tcn 2 "claude-sessions"; }

cmd_attach() {
  local meta; meta=$(meta_for "$1") || return $?
  exec tmux attach -d -t "$(meta_get "$meta" session)"
}

cmd_tail() {
  local meta; meta=$(meta_for "$1") || return $?
  exec tail -F "$(meta_get "$meta" log)"
}

cmd_log() {
  local meta; meta=$(meta_for "$1") || return $?
  exec less +G "$(meta_get "$meta" log)"
}

cmd_peek() {
  local meta; meta=$(meta_for "$1") || return $?
  local n="${2:-30}"
  tmux capture-pane -pt "$(meta_get "$meta" session)" | tail -n "$n"
}

cmd_send() {
  local meta; meta=$(meta_for "$1") || return $?
  local session msg buf
  session=$(meta_get "$meta" session)
  shift
  msg="$*"
  [[ -n "$msg" ]] || { echo "send: message required" >&2; return 64; }
  buf="${session}-msg-$$"
  printf '%s' "$msg" | tmux load-buffer -b "$buf" -
  tmux paste-buffer -d -t "$session" -b "$buf"
  tmux send-keys -t "$session" Enter
  echo "Sent to ${session}: ${msg}"
}

# Kill a single session + cleanup. Internal helper, no prompt.
_kill_one() {
  local ticket="$1"
  local meta="$SESSIONS_DIR/${ticket}/meta"
  [[ -f "$meta" ]] || { echo "  $ticket: no meta, skipping"; return; }
  local session worktree branch
  session=$(meta_get "$meta" session)
  worktree=$(meta_get "$meta" worktree)
  branch=$(meta_get "$meta" branch)
  tmux kill-session -t "$session" 2>/dev/null || true
  if [[ -d "$worktree" ]]; then
    local canonical
    canonical=$(git -C "$worktree" worktree list --porcelain 2>/dev/null \
                | awk '/^worktree / {print $2; exit}')
    if ! git -C "$canonical" worktree remove "$worktree" 2>/dev/null; then
      echo "  $ticket: worktree remove failed (likely uncommitted work in $worktree)"
      return 1
    fi
    git -C "$canonical" branch -D "$branch" >/dev/null 2>&1 || true
  fi
  # Single rm reclaims meta/log/events/results since they all live inside the
  # per-session directory now (BDM-3 layout).
  rm -rf "$SESSIONS_DIR/${ticket}"
  echo "  $ticket: killed, workspace removed, branch deleted"
}

cmd_kill() {
  local with_children=0 with_tree=0 yes=0
  local positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --children) with_children=1; shift ;;
      --tree)     with_tree=1; shift ;;
      --yes|-y)   yes=1; shift ;;
      -*)         echo "kill: unknown flag $1" >&2; return 64 ;;
      *)          positional+=( "$1" ); shift ;;
    esac
  done
  [[ ${#positional[@]} -eq 1 ]] || { echo "kill: exactly one ticket required" >&2; return 64; }
  local ticket="${positional[0]}"
  local meta; meta=$(meta_for "$ticket") || return $?

  # Build the kill set
  local -a victims=( "$ticket" )
  if [[ "$with_tree" -eq 1 ]]; then
    local d
    while IFS= read -r d; do
      [[ -n "$d" ]] && victims+=( "$d" )
    done < <(descendants_of "$ticket")
  elif [[ "$with_children" -eq 1 ]]; then
    local c
    while IFS= read -r c; do
      [[ -n "$c" ]] && victims+=( "$c" )
    done < <(children_of "$ticket")
  fi

  echo "About to kill ${#victims[@]} session(s):"
  for v in "${victims[@]}"; do
    local m="$SESSIONS_DIR/${v}/meta"
    local b s
    b=$(meta_get "$m" branch); s=$(meta_get "$m" session)
    echo "  $v  ($s, $b)"
  done
  if [[ "$yes" -ne 1 ]]; then
    read -rp "Confirm kill + cleanup of all ${#victims[@]}? [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "aborted"; return 0; }
  fi

  # Kill leaves first (descendants before parents) so worktree deletion order is safe.
  for (( i=${#victims[@]}-1; i>=0; i-- )); do
    _kill_one "${victims[$i]}" || true
  done
  echo "done"
}

cmd_clean() {
  local quiet=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -q|--quiet) quiet=1; shift ;;
      -*)         echo "clean: unknown flag $1" >&2; return 64 ;;
      *)          echo "clean: unexpected arg $1" >&2; return 64 ;;
    esac
  done

  # --quiet is implemented by redirecting fd 1 inside a subshell wrapping the
  # body. The redirect dies with the subshell, so the parent shell's stdout
  # is untouched, and the body below stays unchanged — any echo added later
  # is silenced for free with no per-call $QUIET threading.
  (
    (( quiet )) && exec 1>/dev/null
    local meta ticket session
    shopt -s nullglob
    for meta in "$SESSIONS_DIR"/*/meta; do
      ticket=$(basename "$(dirname "$meta")")
      session=$(meta_get "$meta" session)
      if ! tmux has-session -t "$session" 2>/dev/null; then
        echo "removing stale meta: $ticket (session $session is dead)"
        # Remove only the meta file; preserves logs/events for forensics. The
        # full per-session dir is reclaimed by `kill <ticket>`.
        rm -f "$meta"
      fi
    done
  )
}

# ─── Rules engine ─────────────────────────────────────────────────────────────
# A rule is a JSON file at $RULES_DIR/<id>.json with shape:
#   { "id":"...", "wait_for":["BDP-A","BDP-B"], "wait_state":"done",
#     "exec":"<shell command>", "timeout_min":60, "created":"<iso8601>",
#     "label":"human-readable description" }
# When the notify daemon polls, every rule whose wait_for tickets have all
# reached wait_state has its `exec` run and the rule file is removed.
# Rules survive chat session ends. Skills install rules and exit immediately
# instead of polling in-process.

# Returns 0 if every ticket in $1 (comma-separated) is in state $2 (or 'gone').
all_in_state() {
  local tickets="$1" target="$2"
  local IFS=','
  for t in $tickets; do
    [[ -n "$t" ]] || continue
    local meta="$SESSIONS_DIR/${t}/meta"
    [[ -f "$meta" ]] || return 1
    local log session
    log=$(meta_get "$meta" log)
    session=$(meta_get "$meta" session)
    if ! tmux has-session -t "$session" 2>/dev/null; then
      # session dead — count as terminal regardless of target
      continue
    fi
    local state
    state=$(session_state "$log")
    [[ "$state" == "$target" || "$state" == "gone" ]] || return 1
  done
  return 0
}

# Walks $RULES_DIR and fires any rule whose preconditions are met.
# Called once per notify-daemon poll cycle.
evaluate_rules() {
  command -v jq >/dev/null || return 0
  shopt -s nullglob
  local rule_file id wait_for wait_state exec_cmd timeout_min created label
  for rule_file in "$RULES_DIR"/*.json; do
    id=$(jq -r '.id' "$rule_file" 2>/dev/null) || continue
    wait_for=$(jq -r '.wait_for | join(",")' "$rule_file")
    wait_state=$(jq -r '.wait_state // "done"' "$rule_file")
    exec_cmd=$(jq -r '.exec' "$rule_file")
    timeout_min=$(jq -r '.timeout_min // 60' "$rule_file")
    created=$(jq -r '.created' "$rule_file")
    label=$(jq -r '.label // .id' "$rule_file")

    # Timeout check
    local created_epoch now elapsed_min
    created_epoch=$(date -d "$created" +%s 2>/dev/null || echo 0)
    now=$(date +%s)
    elapsed_min=$(( (now - created_epoch) / 60 ))
    if (( created_epoch > 0 && elapsed_min >= timeout_min )); then
      notify-send -u low -a "claude-sessions" \
        "Rule timed out: $label" "after ${elapsed_min}m, removing"
      mv "$rule_file" "$RULES_LOG_DIR/${id}.timed-out.json" 2>/dev/null
      continue
    fi

    # Trigger check
    if all_in_state "$wait_for" "$wait_state"; then
      notify-send -u normal -a "claude-sessions" \
        "Rule firing: $label" "wait_for=$wait_for ($wait_state) → exec"
      # Run the exec asynchronously so a long-running spawn doesn't block the daemon
      nohup bash -c "$exec_cmd" > "$RULES_LOG_DIR/${id}.exec.log" 2>&1 &
      mv "$rule_file" "$RULES_LOG_DIR/${id}.fired.json" 2>/dev/null
    fi
  done
}

cmd_rules() {
  local action="${1:-list}"; [[ $# -gt 0 ]] && shift
  case "$action" in
    list)
      shopt -s nullglob
      local rule_file=( "$RULES_DIR"/*.json )
      if [[ ${#rule_file[@]} -eq 0 ]]; then
        echo "${C_DIM}No pending rules.${C_RESET}"
        return 0
      fi
      printf "${C_BOLD}%-22s %-10s %-30s %-10s %s${C_RESET}\n" \
        "ID" "AGE" "WAIT_FOR" "STATE" "LABEL"
      command -v jq >/dev/null || { echo "jq required for rules"; return 1; }
      local f id wait_for wait_state created label age
      for f in "${rule_file[@]}"; do
        id=$(jq -r '.id' "$f")
        wait_for=$(jq -r '.wait_for | join(",")' "$f")
        wait_state=$(jq -r '.wait_state // "done"' "$f")
        created=$(jq -r '.created' "$f")
        label=$(jq -r '.label // .id' "$f")
        local created_epoch now d
        created_epoch=$(date -d "$created" +%s 2>/dev/null || echo 0)
        now=$(date +%s)
        d=$((now - created_epoch))
        if   (( d < 60 ));    then age="${d}s"
        elif (( d < 3600 ));  then age="$((d/60))m"
        else                       age="$((d/3600))h"; fi
        printf "%-22s %-10s %-30s %-10s %s\n" "$id" "$age" "${wait_for:0:30}" "$wait_state" "${label:0:50}"
      done
      ;;
    show)
      local id="$1"
      [[ -n "$id" ]] || { echo "rules show: id required" >&2; return 64; }
      local f="$RULES_DIR/${id}.json"
      [[ -f "$f" ]] || { echo "no such rule: $id" >&2; return 65; }
      command -v jq >/dev/null && jq . "$f" || cat "$f"
      ;;
    cancel)
      local id="$1"
      [[ -n "$id" ]] || { echo "rules cancel: id required" >&2; return 64; }
      local f="$RULES_DIR/${id}.json"
      [[ -f "$f" ]] || { echo "no such rule: $id" >&2; return 65; }
      mv "$f" "$RULES_LOG_DIR/${id}.cancelled.json"
      echo "cancelled rule $id"
      ;;
    clear)
      shopt -s nullglob
      local files=( "$RULES_DIR"/*.json )
      if [[ ${#files[@]} -eq 0 ]]; then
        echo "no pending rules"
        return 0
      fi
      read -rp "Cancel all ${#files[@]} pending rules? [y/N] " ans
      [[ "$ans" =~ ^[Yy]$ ]] || { echo "aborted"; return 0; }
      local f
      for f in "${files[@]}"; do
        mv "$f" "$RULES_LOG_DIR/$(basename "$f" .json).cancelled.json"
      done
      echo "cleared ${#files[@]} rules"
      ;;
    log)
      # Show recent fired/timed-out/cancelled rules from log dir
      shopt -s nullglob
      local logs=( "$RULES_LOG_DIR"/*.json )
      if [[ ${#logs[@]} -eq 0 ]]; then
        echo "no rule history"
        return 0
      fi
      ls -ltr "$RULES_LOG_DIR"/*.json | tail -20
      ;;
    *)
      echo "rules: unknown action '$action' (list|show|cancel|clear|log)" >&2
      return 64
      ;;
  esac
}

# === Event observability dispatch (BDP-372) ====================================
# Tails per-session events files (written by the PostToolUse event-emitter
# hook at $SESSIONS_DIR/<TICKET>/events) and dispatches each event through
# configured sinks. See .claude/rules/fleet.md → "Event observability".

NOTIFY_DIR="$(_notify_dir)"
NOTIFY_CONFIG="$NOTIFY_DIR/config.toml"
NOTIFY_FIFO="$NOTIFY_DIR/fifo"
NOTIFY_LOG="$NOTIFY_DIR/log"

ensure_notify_config() {
  [[ -f "$NOTIFY_CONFIG" ]] && return 0
  mkdir -p "$NOTIFY_DIR"
  cat >"$NOTIFY_CONFIG" <<'EOF'
# claude-sessions notification routing — BDP-372 fleet event observability.
# Per-event-kind list of sinks. Sinks: desktop, bell, fifo, slack.
[events]
review_summary = ["desktop"]
merge          = ["desktop", "bell"]
pr_opened      = ["desktop"]
review_comment = []
commit_pushed  = []
EOF
}

# Echo one sink name per line for a given event kind.
notify_sinks_for() {
  local kind="$1"
  [[ -f "$NOTIFY_CONFIG" ]] || return 0
  awk -v kind="$kind" '
    /^\[events\]/ { in_events=1; next }
    /^\[/         { in_events=0 }
    in_events && $0 ~ "^"kind"[[:space:]]*=" {
      sub(/^[^=]*=[[:space:]]*\[/, "")
      sub(/\][[:space:]]*$/, "")
      gsub(/[" ]/, "")
      n = split($0, arr, ",")
      for (i=1; i<=n; i++) if (arr[i] != "") print arr[i]
    }' "$NOTIFY_CONFIG"
}

sink_desktop() {
  local title="$1" body="$2" kind="$3"
  local urgency="normal"
  case "$kind" in
    error|merge)                  urgency="critical" ;;
    review_comment|commit_pushed) urgency="low" ;;
  esac
  notify-send -u "$urgency" -a "claude-sessions" "$title" "$body" \
    2>>"$NOTIFY_LOG" || true
}

sink_bell() {
  local title="$1" body="$2"
  printf '\a' >&2 || true
  printf '🔔 %s — %s\n' "$title" "$body" >&2 || true
}

sink_fifo() {
  local event="$1"
  if [[ ! -p "$NOTIFY_FIFO" ]]; then
    mkfifo "$NOTIFY_FIFO" 2>>"$NOTIFY_LOG" || return 0
  fi
  # Non-blocking — if no reader, drop rather than blocking the daemon
  ( exec 3>"$NOTIFY_FIFO"; printf '%s\n' "$event" >&3; exec 3>&-; ) &
  local writer_pid=$!
  ( sleep 1; kill "$writer_pid" 2>/dev/null || true ) &
}

sink_slack() {
  local title="$1" body="$2"
  [[ -n "${CLAUDE_SESSIONS_SLACK_WEBHOOK:-}" ]] || return 0
  local payload
  payload="$(jq -nc --arg t "$title" --arg b "$body" \
    '{text:"\($t)\n\($b)"}' 2>>"$NOTIFY_LOG")" || return 0
  curl -fsS -m 5 -H 'Content-Type: application/json' \
    --data "$payload" "$CLAUDE_SESSIONS_SLACK_WEBHOOK" \
    >/dev/null 2>>"$NOTIFY_LOG" || true
}

# Phase 12.10 (BDM-28, B15). ntfy webhook sink. Reads the per-project
# ${CLAUDE_PLUGIN_DATA}/projects/<KEY>/web/settings.toml [mobile] block
# (written by the dashboard's Settings page) and POSTs to the topic
# when mobile.enabled and the kind is in mobile.kinds.
sink_ntfy() {
  local title="$1" body="$2" kind="$3"
  local cfg="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data}/projects/${CLAUDE_PROJECT_KEY:-}/web/settings.toml"
  [[ -f "$cfg" ]] || return 0
  local enabled url topic kinds
  enabled="$(awk -F'=' '/^\[mobile\]/{f=1;next} /^\[/{f=0} f && $1~/^enabled/{gsub(/[ "]/,"",$2);print $2;exit}' "$cfg")"
  [[ "$enabled" == "true" ]] || return 0
  url="$(awk -F'=' '/^\[mobile\]/{f=1;next} /^\[/{f=0} f && $1~/^ntfy_url/{gsub(/^[ ]*"|"[ ]*$/,"",$2);print $2;exit}' "$cfg")"
  topic="$(awk -F'=' '/^\[mobile\]/{f=1;next} /^\[/{f=0} f && $1~/^topic/{gsub(/^[ ]*"|"[ ]*$/,"",$2);print $2;exit}' "$cfg")"
  kinds="$(awk -F'=' '/^\[mobile\]/{f=1;next} /^\[/{f=0} f && $1~/^kinds/{gsub(/^[ ]*"|"[ ]*$/,"",$2);print $2;exit}' "$cfg")"
  [[ -n "$url" && -n "$topic" ]] || return 0
  if [[ -n "$kinds" && ! "$kinds" =~ (^|,)"$kind"($|,) ]]; then
    return 0
  fi
  curl -fsS -m 5 -H "Title: $title" --data "$body" "${url%/}/$topic" \
    >/dev/null 2>>"$NOTIFY_LOG" || true
}

# Dispatch one event through configured sinks.
# Args: ticket kind detail_json event_json
dispatch_event() {
  local ticket="$1" kind="$2" detail="$3" event="$4"
  local sinks
  mapfile -t sinks < <(notify_sinks_for "$kind")
  [[ "${#sinks[@]}" -eq 0 ]] && return 0
  local title body
  title="claude $ticket: $kind"
  body="$(jq -r 'to_entries|map("\(.key)=\(.value)")|join(" ")' <<<"$detail" 2>/dev/null || echo "")"
  for sink in "${sinks[@]}"; do
    case "$sink" in
      desktop) sink_desktop "$title" "$body" "$kind" ;;
      bell)    sink_bell    "$title" "$body" ;;
      fifo)    sink_fifo    "$event" ;;
      slack)   sink_slack   "$title" "$body" ;;
      ntfy)    sink_ntfy    "$title" "$body" "$kind" ;;
      *) printf '%s [warn] unknown sink %q for kind %q\n' \
           "$(date -u +%FT%TZ)" "$sink" "$kind" >>"$NOTIFY_LOG" ;;
    esac
  done
}

# Read new event lines for one session and dispatch them.
# On first encounter (no offset file), starts from current EOF — historical
# events are NOT replayed, to avoid spam on daemon (re)start.
tail_session_events() {
  local ticket="$1"
  local events_file="$SESSIONS_DIR/${ticket}/events"
  [[ -f "$events_file" ]] || return 0
  local offset_file="$SESSIONS_DIR/${ticket}/events.offset"
  local prev_offset cur_size
  prev_offset="$(cat "$offset_file" 2>/dev/null || true)"
  cur_size="$(stat -c%s "$events_file" 2>/dev/null || echo 0)"
  if [[ -z "$prev_offset" ]]; then
    echo "$cur_size" > "$offset_file"
    return 0
  fi
  if (( cur_size <= prev_offset )); then
    return 0
  fi
  local new_chunk
  new_chunk="$(tail -c +"$((prev_offset+1))" "$events_file" 2>>"$NOTIFY_LOG" || true)"
  echo "$cur_size" > "$offset_file"
  [[ -z "$new_chunk" ]] && return 0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local kind detail
    kind="$(jq -r '.kind // empty' <<<"$line" 2>/dev/null || true)"
    [[ -z "$kind" ]] && continue
    detail="$(jq -c '.detail // {}' <<<"$line" 2>/dev/null || echo '{}')"
    dispatch_event "$ticket" "$kind" "$detail" "$line" || true
  done <<<"$new_chunk"
}

# === end event observability ===================================================

# claude-sessions events <TICKET> [flags] — read tool-level events for a session.
# See .claude/rules/fleet.md → "Event observability" / "Querying the event log".
cmd_events() {
  local ticket="" since="" kinds="" format="plain" follow=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since=*)   since="${1#--since=}"; shift ;;
      --since)     since="$2"; shift 2 ;;
      --kinds=*)   kinds="${1#--kinds=}"; shift ;;
      --kinds)     kinds="$2"; shift 2 ;;
      --json)      format="json"; shift ;;
      --plain)     format="plain"; shift ;;
      --follow|-f) follow=1; shift ;;
      -*) echo "events: unknown flag $1" >&2; return 64 ;;
      *)
        if [[ -z "$ticket" ]]; then ticket="$1"; shift
        else echo "events: unexpected positional arg: $1" >&2; return 64
        fi
        ;;
    esac
  done

  if [[ -z "$ticket" ]]; then
    echo "events: missing <ticket>" >&2
    echo "usage: claude-sessions events <ticket> [--since=TS] [--kinds=K,..] [--json|--plain] [--follow]" >&2
    return 64
  fi

  local events_file="$SESSIONS_DIR/${ticket}/events"
  # Empty/missing events file → exit 0 with no output (per spec).
  if [[ ! -f "$events_file" ]]; then
    [[ "$follow" -eq 1 ]] || return 0
    # In follow mode, wait for the file to appear.
    while [[ ! -f "$events_file" ]]; do sleep 0.5; done
  fi

  # Build a jq filter: optional since + kinds.
  local filter='.'
  if [[ -n "$since" ]]; then
    filter="$filter | select(.ts >= \$since)"
  fi
  if [[ -n "$kinds" ]]; then
    # Convert "a,b,c" to a jq array literal
    local kinds_jq
    kinds_jq="$(jq -nc --arg s "$kinds" '$s | split(",")')"
    filter="$filter | select(.kind as \$k | $kinds_jq | index(\$k))"
  fi

  # Output stage — per format.
  local emit
  case "$format" in
    json)  emit='.' ;;
    plain) emit='
      .ts as $t | .kind as $k | .detail as $d
      | ($t | sub("^[0-9-]+T";"") | sub("Z$";"")) as $hms
      | ($d | to_entries | map("\(.key)=\(.value)") | join(" ")) as $body
      | "\($hms)  \($k)  \($body)"' ;;
  esac

  if [[ "$follow" -eq 0 ]]; then
    jq -rc --arg since "$since" "$filter | $emit" "$events_file" 2>/dev/null || true
    return 0
  fi

  # Follow mode — show existing events, then tail. SIGINT exits cleanly.
  trap 'exit 0' INT
  jq -rc --arg since "$since" "$filter | $emit" "$events_file" 2>/dev/null || true
  tail -n0 -f "$events_file" 2>/dev/null \
    | jq -rc --arg since "$since" --unbuffered "$filter | $emit" 2>/dev/null || true
}

cmd_notify() {
  local interval=5 once=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interval) interval="$2"; shift 2 ;;
      --once)     once=1; shift ;;
      *) echo "notify: unknown flag $1" >&2; return 64 ;;
    esac
  done

  # Fleet child sessions don't run their own daemon — the parent's daemon
  # already covers the project. Exit 0 immediately to avoid log spam and
  # pointless lock-poll wakeups when many children spawn (BDM-4 §4).
  if (( "${CLAUDE_SESSION_DEPTH:-0}" >= 1 )); then
    return 0
  fi

  mkdir -p "$NOTIFY_DIR"
  local pid_file="$NOTIFY_DIR/pid"

  command -v notify-send >/dev/null \
    || { echo "notify-send not found (apt install libnotify-bin)" >&2; return 1; }
  ensure_notify_config

  # --once skips lock and standby — single-pass evaluation for testing/scripts.
  if [[ "$once" -eq 1 ]]; then
    _notify_run_loop "$interval" 1
    return 0
  fi

  # Stand-by lock pattern (BDM-4): if another monitor in this project already
  # holds the lock, poll until it's released. With two Claude Code sessions
  # in the same project, exactly one monitor runs and the other stands by;
  # when the active session closes (SIGTERM → trap → rm pid_file → exit),
  # the stand-by takes over within ~$interval seconds. Continuous coverage
  # as long as ANY session is alive in the project.
  while true; do
    if _try_acquire_pid_lock "$pid_file"; then
      # Trap covers the signals Claude Code might use (undocumented; we trap
      # all three for defensive coverage — see fleet/docs/research/0001).
      trap 'rm -f "'"$pid_file"'"; exit 0' INT TERM HUP
      echo "notify: lock acquired (pid $$), polling every ${interval}s (Ctrl-C to stop)"
      _notify_run_loop "$interval" 0
      rm -f "$pid_file"
      return 0
    fi
    # Lock held by a live peer — stand by.
    sleep "$interval"
  done
}

# Try to acquire the per-project notify lock.
#   - Returns 0 (acquired) if the file didn't exist OR holder PID is dead
#     (stale-PID reclaim — necessary because no Claude Code respawn picks up
#      after a crashed daemon, see fleet/docs/research/0001).
#   - Returns 1 (held) if a live process owns the file.
_try_acquire_pid_lock() {
  local pid_file="$1" holder
  if [[ -f "$pid_file" ]]; then
    holder="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$holder" ]] && kill -0 "$holder" 2>/dev/null; then
      return 1   # live holder
    fi
    # Stale — holder is dead. Fall through to reclaim.
  fi
  echo $$ > "$pid_file"
  return 0
}

# Inner polling loop. Args: interval, once_flag (1=single pass, 0=loop).
# Caller is responsible for the lock + trap.
_notify_run_loop() {
  local interval="$1" once="$2"
  declare -A last_state
  declare -A first_seen=()
  declare -A ceiling_notified=()

  while true; do
    local sessions
    mapfile -t sessions < <(list_known_sessions)
    for t in "${sessions[@]}"; do
      local meta="$SESSIONS_DIR/${t}/meta"
      [[ -f "$meta" ]] || continue
      local log session state prev
      log=$(meta_get "$meta" log)
      session=$(meta_get "$meta" session)
      if ! tmux has-session -t "$session" 2>/dev/null; then
        # session died — notify once then forget
        if [[ -n "${last_state[$t]:-}" && "${last_state[$t]}" != "gone" ]]; then
          notify-send -u low -a "claude-sessions" "claude $t: session ended" \
            "tmux session '$session' is gone"
          last_state[$t]="gone"
        fi
        continue
      fi
      state=$(session_state "$log")
      prev="${last_state[$t]:-}"

      if [[ -z "$prev" && -z "${first_seen[$t]:-}" ]]; then
        # First time we've seen this session
        notify-send -u low -a "claude-sessions" "claude $t: spawned" "branch $(meta_get "$meta" branch)"
        first_seen[$t]=1
      elif [[ "$prev" != "$state" ]]; then
        case "$state" in
          needs-input)
            notify-send -u critical -a "claude-sessions" \
              "claude $t: needs input" \
              "Attach: claude-sessions attach $t" ;;
          error)
            notify-send -u critical -a "claude-sessions" \
              "claude $t: error" \
              "Tail: claude-sessions tail $t" ;;
          done)
            notify-send -u normal -a "claude-sessions" \
              "claude $t: done" \
              "Peek: claude-sessions peek $t" ;;
          # working/idle/starting transitions are silent
        esac
      fi
      last_state[$t]="$state"

      # ─── Tool-level event observability (BDP-372) ──────────────────────────
      # Tail $SESSIONS_DIR/${t}/events for new lines and dispatch each
      # through configured sinks per $NOTIFY_DIR/config.toml.
      tail_session_events "$t" || true

      # ─── Ceiling enforcement ───────────────────────────────────────────────
      # If meta declares max_cost_usd or max_runtime_min, check and act.
      local max_cost max_rt tokens cost rt
      max_cost=$(meta_get "$meta" max_cost_usd)
      max_rt=$(meta_get "$meta" max_runtime_min)
      if [[ -n "$max_cost" || -n "$max_rt" ]]; then
        tokens=$(latest_tokens "$log")
        cost=$(est_cost_usd "$tokens")
        rt=$(runtime_min "$meta")
        local breached="" how=""
        if [[ -n "$max_cost" ]] && awk -v c="$cost" -v m="$max_cost" 'BEGIN{exit !(c>=m)}'; then
          breached=1; how="cost \$$cost ≥ \$$max_cost cap"
        fi
        if [[ -n "$max_rt" ]] && (( rt >= max_rt )); then
          breached=1; how="${how:+$how, }runtime ${rt}m ≥ ${max_rt}m cap"
        fi
        if [[ -n "$breached" && -z "${ceiling_notified[$t]:-}" ]]; then
          notify-send -u critical -a "claude-sessions" \
            "claude $t: ceiling reached" \
            "$how — sending graceful stop. claude-sessions kill $t to force."
          # Send a graceful stop message to the session; do not kill outright.
          local buf="${session}-ceiling-$$"
          printf 'STOP — you have reached your declared ceiling (%s). Wrap up your current edit, push if appropriate, and exit. Do not start new work.' "$how" \
            | tmux load-buffer -b "$buf" - 2>/dev/null
          tmux paste-buffer -d -t "$session" -b "$buf" 2>/dev/null
          tmux send-keys -t "$session" Enter 2>/dev/null
          ceiling_notified[$t]=1
        fi
      fi
    done
    # Rules engine: fire any rule whose preconditions are met.
    evaluate_rules
    [[ "$once" -eq 1 ]] && break
    sleep "$interval"
  done
}

cmd_web() {
  # BDM-15: discovery-only. The web monitor (claude-sessions-web) is started
  # by Claude Code via monitors/monitors.json and binds a per-project port
  # written to ${CLAUDE_PLUGIN_DATA}/projects/<KEY>/web/config.toml. This
  # subcommand reads that config and prints the URL — it does NOT start a
  # server.
  local web_dir cfg
  web_dir="$(_web_dir)"
  cfg="$web_dir/config.toml"
  if [[ ! -f "$cfg" ]]; then
    cat >&2 <<EOF
fleet web dashboard hasn't started for this project yet ($cfg not found).

The dashboard runs as a plugin monitor; it starts when Claude Code loads
the plugin. If it isn't running:
  - At depth >= 1 (fleet child session), the monitor short-circuits — the
    parent session's monitor covers the project.
  - Otherwise, try \`/plugin reload fleet\` to kick the monitor.
EOF
    return 1
  fi
  local port bind
  port=$(awk -F'=' '/^[[:space:]]*port[[:space:]]*=/ {gsub(/[[:space:]]/,"",$2); print $2; exit}' "$cfg")
  bind=$(awk -F'=' '/^[[:space:]]*bind[[:space:]]*=/ {gsub(/^[[:space:]]+|[[:space:]]+$/,"",$2); gsub(/"/,"",$2); print $2; exit}' "$cfg")
  bind="${bind:-127.0.0.1}"
  echo "fleet dashboard: http://${bind}:${port}/"
  local pid_file="$web_dir/pid" pid pid_alive=0
  if [[ -f "$pid_file" ]]; then
    pid=$(cat "$pid_file" 2>/dev/null)
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      pid_alive=1
    fi
  fi
  if (( pid_alive == 0 )); then
    echo "  ⚠ monitor not running (no live PID at $pid_file). Try \`/plugin reload fleet\`." >&2
    return 2
  fi
}

cmd_tui() {
  while true; do
    clear
    cmd_list
    echo
    mapfile -t sessions < <(list_known_sessions)
    if [[ ${#sessions[@]} -eq 0 ]]; then exit 0; fi
    PS3=$'\nticket # then action (or q to quit): '
    select t in "${sessions[@]}"; do
      [[ -n "$t" ]] || continue
      echo
      PS3=$'action: '
      select a in attach tail peek send kill back; do
        case "$a" in
          attach) cmd_attach "$t"; break 2 ;;
          tail)   cmd_tail "$t" ;;
          peek)   cmd_peek "$t"; read -rp "[enter] " ;;
          send)   read -rp "message: " m; cmd_send "$t" "$m" ;;
          kill)   cmd_kill "$t"; break 2 ;;
          back)   break ;;
        esac
      done
      break
    done
  done
}

# Dispatch — skipped when this file is sourced (lets tests pull in the
# helper functions without triggering the default "list" command).
if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
  return 0 2>/dev/null || true
fi

case "${1:-list}" in
  ""|list) cmd_list ;;
  watch)   cmd_watch ;;
  attach)  shift; cmd_attach "$@" ;;
  tail)    shift; cmd_tail "$@" ;;
  log)     shift; cmd_log "$@" ;;
  peek)    shift; cmd_peek "$@" ;;
  send)    shift; cmd_send "$@" ;;
  kill)    shift; cmd_kill "$@" ;;
  clean|cleanup) shift; cmd_clean "$@" ;;
  tui)     cmd_tui ;;
  notify)  shift; cmd_notify "$@" ;;
  events)  shift; cmd_events "$@" ;;
  web)     shift; cmd_web "$@" ;;
  rules)   shift; cmd_rules "$@" ;;
  tree)    shift; cmd_tree "$@" ;;
  cost)    shift; cmd_cost "$@" ;;
  -h|--help|help) sed -n '2,33p' "$0" | sed 's/^# *//' ;;
  *) echo "unknown subcommand: $1 (try: claude-sessions help)" >&2; exit 64 ;;
esac
