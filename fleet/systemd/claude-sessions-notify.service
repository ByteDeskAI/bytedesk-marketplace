[Unit]
Description=claude-sessions desktop notifier (alerts on session state changes)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/claude-sessions notify --interval 5
Restart=on-failure
RestartSec=5
# Keep the journal noise low; the daemon prints "polling every Ns" once
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
