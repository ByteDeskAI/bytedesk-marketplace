{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pr-merge-guard.sh",
          "timeout": 10,
          "statusMessage": "Merge guard: checking PR-number authorization..."
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/event-emitter.sh",
          "timeout": 5
        }
      ]
    }
  ]
}
